// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - name: string (required) - Display name
//   - photoURL: string (optional) - Profile picture URL
//
// Collection: unavailability
// Document ID: {userId}_{date}
// Fields:
//   - userId: string (required) - UID of the user
//   - userName: string (required) - Name of the user
//   - date: string (required) - ISO date string (YYYY-MM-DD)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500));
    }

    function isValidUnavailability(data) {
      return data.keys().hasAll(['userId', 'userName', 'date']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /unavailability/{unavailabilityId} {
      allow read: if isAuthenticated();
      // Document ID should be {userId}_{date}
      allow create: if isAuthenticated() && 
                      isValidUnavailability(request.resource.data) && 
                      unavailabilityId == request.auth.uid + "_" + request.resource.data.date;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
